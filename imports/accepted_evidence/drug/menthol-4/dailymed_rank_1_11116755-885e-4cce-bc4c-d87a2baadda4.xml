               <text>
                  <paragraph>
                     <content styleCode="bold">NDC 82944-104-10</content>
                  </paragraph>
                  <paragraph>
                     <content styleCode="bold">ION PHARMA MEDICINE FORWARD</content>
                  </paragraph>
                  <paragraph>
