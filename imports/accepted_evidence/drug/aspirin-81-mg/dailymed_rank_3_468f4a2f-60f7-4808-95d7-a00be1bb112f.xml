               <code code="44425-7" codeSystem="2.16.840.1.113883.6.1" displayName="STORAGE AND HANDLING SECTION"/>
               <title>
                  <content styleCode="bold">
                     <content styleCode="italics">Other information</content>
                  </content>
               </title>
               <text>
                  <list listType="unordered" styleCode="Square">
                     <item>store at 25°C (77°F); excursions permitted between 15°-30°C (59°-86°F)</item>
                     <item>see end flap for expiration date and lot number</item>
                  </list>
               </text>
               <effectiveTime value="20260402"/>
            </section>
         </component>
