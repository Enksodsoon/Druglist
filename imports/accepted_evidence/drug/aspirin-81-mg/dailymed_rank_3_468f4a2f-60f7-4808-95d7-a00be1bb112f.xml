               <code code="55106-9" codeSystem="2.16.840.1.113883.6.1" displayName="OTC - ACTIVE INGREDIENT SECTION"/>
               <title>
                  <content styleCode="bold">
                     <content styleCode="italics">Active ingredient (in each tablet)</content>
                  </content>
               </title>
               <text>
                  <paragraph>Aspirin 81 mg (NSAID)*<br/>
*nonsteroidal anti-inflammatory drug</paragraph>
               </text>
               <effectiveTime value="20260402"/>
            </section>
