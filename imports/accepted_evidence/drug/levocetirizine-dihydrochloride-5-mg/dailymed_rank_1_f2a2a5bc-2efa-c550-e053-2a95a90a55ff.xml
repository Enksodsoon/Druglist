               <code code="51945-4" codeSystem="2.16.840.1.113883.6.1" displayName="PACKAGE LABEL.PRINCIPAL DISPLAY PANEL"/>
               <text>
                  <paragraph>
                     <content styleCode="bold">curist</content>
                  </paragraph>
                  <paragraph/>
                  <paragraph>
                     <content styleCode="bold">Allergy Relief</content>
                  </paragraph>
                  <paragraph/>
                  <paragraph>Levocetirizine Dihydrochloride Tablets, USP 5 mg</paragraph>
                  <paragraph>Antihistamine</paragraph>
                  <paragraph/>
                  <paragraph>24 Hour Relief of Runny Nose; Sneezing; Itchy, Watery Eyes; Itchy Nose or Throat</paragraph>
                  <paragraph/>
                  <paragraph>180 Tablets</paragraph>
                  <paragraph>
                     <content styleCode="bold">curistrelief.com</content>
                  </paragraph>
