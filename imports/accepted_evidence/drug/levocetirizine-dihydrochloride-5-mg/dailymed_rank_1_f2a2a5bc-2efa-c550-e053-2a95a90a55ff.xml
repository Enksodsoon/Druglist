         <component>
            <section ID="id_link_f2a3c993-1a42-4f74-e053-2a95a90aadb5">
               <id root="f2a3c993-1a41-4f74-e053-2a95a90aadb5"/>
               <code code="34068-7" codeSystem="2.16.840.1.113883.6.1" displayName="DOSAGE &amp; ADMINISTRATION SECTION"/>
               <text>
                  <paragraph>
                     <content styleCode="italics">
                        <content styleCode="bold">Directions</content>
                     </content>
                  </paragraph>
                  <paragraph/>
                  <table border="0" width="100%">
                     <tbody>
                        <tr>
                           <td>adults 65 years and older</td>
                           <td>ask a doctor</td>
                        </tr>
                        <tr>
                           <td>adults and children 12-64 years</td>
                           <td>
                              <list listType="unordered">
                                 <item>take 1 tablet (5 mg) once daily in the evening</item>
                                 <item>do not take more than 1 tablet (5 mg) in 24 hours</item>
                                 <item>½ tablet (2.5 mg) once daily in the evening may be appropriate for less severe symptoms</item>
                              </list>
                           </td>
                        </tr>
                        <tr>
                           <td>children 6-11 years</td>
                           <td>
                              <list listType="unordered">
                                 <item>take ½ tablet (2.5 mg) once daily in the evening</item>
                                 <item>do not take more than ½ tablet (2.5 mg) in 24 hours</item>
                              </list>
                           </td>
                        </tr>
                        <tr>
                           <td>children under 6 years</td>
                           <td>do not use</td>
                        </tr>
                        <tr>
                           <td>consumers with kidney disease</td>
                           <td>do not use</td>
                        </tr>
                     </tbody>
                  </table>
                  <paragraph/>
               </text>
               <effectiveTime value="20230119"/>
            </section>
         </component>
         <component>
            <section ID="id_link_f2a3d32a-d8aa-f1b7-e053-2995a90a69cb">
