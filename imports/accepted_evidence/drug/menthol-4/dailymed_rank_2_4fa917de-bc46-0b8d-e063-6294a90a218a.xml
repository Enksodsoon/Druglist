               <component>
                  <section ID="id_link_b865b1aa-5869-71d0-e053-2995a90add1a">
                     <id root="4fa94c2f-bd52-6f54-e063-6294a90a66a5"/>
                     <code code="50565-1" codeSystem="2.16.840.1.113883.6.1" displayName="OTC - KEEP OUT OF REACH OF CHILDREN SECTION"/>
                     <title>Keep out of reach of children and pets</title>
                     <text>
                        <paragraph>If swallowed, get medical help or contact a Poison Control Center ( 1800-222-1222) right away</paragraph>
                     </text>
                     <effectiveTime value="20260401"/>
                  </section>
