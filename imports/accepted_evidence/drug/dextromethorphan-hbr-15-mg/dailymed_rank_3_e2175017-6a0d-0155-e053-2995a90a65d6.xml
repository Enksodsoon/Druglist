            <section ID="id_link_e2165adc-ce98-cc3c-e053-2a95a90a4cbf">
               <id root="e2165adc-ce97-cc3c-e053-2a95a90a4cbf"/>
               <code code="55106-9" codeSystem="2.16.840.1.113883.6.1" displayName="OTC - ACTIVE INGREDIENT SECTION"/>
               <text>
                  <paragraph>Dextromethorphan HBr, USP 15 mg</paragraph>
                  <paragraph/>
               </text>
               <effectiveTime value="20220622"/>
            </section>
