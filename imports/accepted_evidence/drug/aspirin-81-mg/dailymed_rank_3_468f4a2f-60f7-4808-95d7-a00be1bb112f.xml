         <component>
            <section ID="LINK_f9e6b486-e6bc-410e-a544-15713934d7c9">
               <id root="9d7a6dab-6530-4e28-b290-dd0379fd34e5"/>
               <code code="34068-7" codeSystem="2.16.840.1.113883.6.1" displayName="DOSAGE &amp; ADMINISTRATION SECTION"/>
               <title>
                  <content styleCode="bold">
                     <content styleCode="italics">Directions</content>
                  </content>
               </title>
               <text>
                  <list listType="unordered" styleCode="Square">
                     <item>
                        <content styleCode="bold">do not take more than directed</content>
                     </item>
                     <item>drink a full glass of water with each dose</item>
                     <item>adults and children 12 years and over: take 4 to 8 tablets every 4 hours not to exceed 48 tablets in 24 hours unless directed by a doctor</item>
                     <item>children under 12 years: do not use unless directed by a doctor</item>
                  </list>
               </text>
               <effectiveTime value="20260402"/>
            </section>
         </component>
         <component>
            <section ID="LINK_41e4860b-ef4a-428a-884e-468decfb89f0">
