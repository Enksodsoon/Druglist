                                <li >
                                    <a href="#" id="anch_dj_dj-dj_17" class="">16 HOW SUPPLIED/STORAGE AND HANDLING</a>
                                    
                                    <div class="Section toggle-content closed long-content" data-sectioncode="34069-5">
