               <code code="34067-9" codeSystem="2.16.840.1.113883.6.1" displayName="INDICATIONS &amp; USAGE SECTION"/>
               <text>
                  <paragraph>Usage: Soothes, Softens and Moisturizes Dry Rough Skin.</paragraph>
               </text>
               <effectiveTime value="20220923"/>
            </section>
         </component>
         <component>
            <section ID="ID_10222148-da17-4842-8be3-ae2a898ced93">
               <id root="e994fa05-a44d-2555-e053-2a95a90ae83b"/>
               <code code="34071-1" codeSystem="2.16.840.1.113883.6.1" displayName="WARNINGS SECTION"/>
               <title>WARNINGS SECTION</title>
               <text>
                  <paragraph>
                     <content styleCode="bold">Caution:</content> Do not apply to broken skin. If redness occurs, discontinue use. Avoid contact with eyes.
      

 </paragraph>
               </text>
               <effectiveTime value="20220923"/>
            </section>
         </component>
