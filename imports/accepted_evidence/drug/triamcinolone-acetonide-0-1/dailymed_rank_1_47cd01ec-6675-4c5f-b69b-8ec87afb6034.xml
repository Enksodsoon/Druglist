               <code code="34089-3" codeSystem="2.16.840.1.113883.6.1" displayName="DESCRIPTION SECTION"/>
               <title>DERMAVYX DESCRIPTION</title>
               <text>
                  <paragraph>
                     <content styleCode="Bold">Dermavyx is supplied as 4 components in a<content styleCode="italics"> kit</content>: </content>
                  </paragraph>
                  <paragraph>- 1 TUBE OF TRIAMCINOLONE ACETONIDE CREAM 0.1%, 80g</paragraph>
                  <paragraph>- 30 SHEETS OF TRANSPARENT DRESSING (3 BOXES OF 10 SHEETS)</paragraph>
                  <paragraph/>
               </text>
               <effectiveTime value="20260505"/>
            </section>
         </component>
         <component>
            <section>
               <id root="8c5a68ea-6c01-4252-8429-d6326523e75f"/>
               <code code="34067-9" codeSystem="2.16.840.1.113883.6.1" displayName="INDICATIONS &amp; USAGE SECTION"/>
               <title>INDICATION AND USAGE</title>
               <text>
                  <paragraph>Indicated for the relief of the inflammatory and pruritic manifestations of corticosteroid-responsive dermatoses.</paragraph>
               </text>
               <effectiveTime value="20260505"/>
            </section>
