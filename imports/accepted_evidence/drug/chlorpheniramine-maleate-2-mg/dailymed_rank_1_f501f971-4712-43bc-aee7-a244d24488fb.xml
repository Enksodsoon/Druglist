               <code code="55106-9" codeSystem="2.16.840.1.113883.6.1" displayName="OTC - ACTIVE INGREDIENT SECTION"/>
               <text>
                  <content styleCode="emphasis"/>
                  <br/>
                  <content styleCode="bold">Active Ingredients (in each caplet)</content>
                  <br/>Acetaminophen 500 mg<br/>Chlorpheniramine maleate 2 mg<br/>Phenylephrine HCl 5 mg<br/>
               </text>
               <effectiveTime value="20100203"/>
            </section>
         </component>
         <component>
            <section>
               <id root="62ca1026-02fd-4c76-9b90-58be11c31e6d"/>
               <code code="55105-1" codeSystem="2.16.840.1.113883.6.1" displayName="OTC - PURPOSE SECTION"/>
               <text>
                  <paragraph>
                     <content styleCode="bold">Purposes</content>
                     <br/>Pain reliever/Fever Reducer<br/>Antihistamine<br/>Nasal Decongestant</paragraph>
                  <paragraph>
                     <br/>
                  </paragraph>
               </text>
               <effectiveTime value="20100203"/>
            </section>
         </component>
         <component>
            <section>
               <id root="fd719bed-bca3-463f-b2c4-eb0c80d7b5ac"/>
               <code code="34068-7" codeSystem="2.16.840.1.113883.6.1" displayName="DOSAGE &amp; ADMINISTRATION SECTION"/>
               <text>
                  <paragraph>
                     <content styleCode="bold">Directions</content>
                  </paragraph>
                  <paragraph>
                     <content styleCode="bold">Adults:</content> Take 1 to 2 caplets with water every 6 hours as needed; do not take more than 8 caplets in 24 hours or as directed by a doctor.<br/>
                  </paragraph>
               </text>
               <effectiveTime value="20100203"/>
            </section>
         </component>
