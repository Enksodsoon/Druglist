                     <code code="50569-3" codeSystem="2.16.840.1.113883.6.1" displayName="OTC - ASK DOCTOR SECTION"/>
                     <title>Stop and ask a doctor</title>
                     <text>
                        <paragraph/>
                        <paragraph>■ skin irritation develops</paragraph>
                        <paragraph>■ condition worsens</paragraph>
                        <paragraph>■ symptoms persist for more than 7 days or clear up and occur again within a few days</paragraph>
                        <paragraph/>
                     </text>
                     <effectiveTime value="20260401"/>
                  </section>
               </component>
               <component>
