               <code code="60561-8" codeSystem="2.16.840.1.113883.6.1" displayName="OTHER SAFETY INFORMATION"/>
               <title>
                  <content styleCode="bold">
                     <content styleCode="italics">Other information</content>
                  </content>
               </title>
               <text>
                  <paragraph>■ store between 20-25°C (68-77°F)
  <br/>
■ protect from excessive moisture
  <br/>
■ retain carton for complete product information and warnings
 </paragraph>
               </text>
               <effectiveTime value="20260408"/>
            </section>
         </component>
