            <section ID="id_link_3283c8d4-9cc4-5d50-e054-00144ff8d46c">
               <id root="9b057180-8ff3-2590-e053-2a95a90a909f"/>
               <code code="34067-9" codeSystem="2.16.840.1.113883.6.1" displayName="INDICATIONS &amp; USAGE SECTION"/>
               <title>
                  <content styleCode="bold">
                     <content styleCode="italics">Uses</content>
                  </content>
               </title>
               <text>
                  <paragraph>temporarily relieves these symptoms of hay fever or other upper respiratory allergies:</paragraph>
                  <list listType="unordered">
                     <item>runny nose</item>
                     <item>sneezing</item>
                     <item>itchy nose or throat</item>
                     <item>itchy, watery eyes</item>
                  </list>
               </text>
               <effectiveTime value="20151101"/>
            </section>
         </component>
