               <title>
                  <content styleCode="bold">
                     <content styleCode="italics">Other information</content>
                  </content>
               </title>
               <text>
                  <list listType="unordered">
                     <item>
                        <content styleCode="bold">each tablet contains: </content>calsium 40 mg
  </item>
                     <item>store at 15°-30°C (59°-86°F)</item>
                  </list>
               </text>
               <effectiveTime value="20151101"/>
            </section>
         </component>
